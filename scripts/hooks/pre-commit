#!/usr/bin/env bash
# pre-commit — Beckn Protocol RFC consistency checks.
#
# For each staged docs/*.md file (and the reading_order env file):
#   1. TOC consistency: stale TOCs are regenerated via scripts/update_toc.py
#      and the fixed files are re-staged so the commit proceeds with the
#      auto-fixed content.
#   2. README regeneration: scripts/update_readme.py is invoked whenever
#      scripts/reading_order.env or any docs/*.md file is staged. The
#      regenerated docs/README.md is re-staged automatically.
#   3. Docs index consistency: every RFC document on disk must be listed in
#      scripts/reading_order.env, and every entry there must be linked in both
#      docs/README.md and docs/RFC_Publication_Summary.md. README TODO
#      placeholders fail the hook (they signal an unfilled description).
#
# Canonical source: scripts/hooks/pre-commit. Installed to .git/hooks/pre-commit.
#
# Re-install (e.g. after pulling a newer version of this script):
#   ln -sf ../../scripts/hooks/pre-commit .git/hooks/pre-commit

set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"

# Collect staged Markdown files under docs/ plus the reading_order env file.
mapfile -t STAGED_DOCS < <(git diff --cached --name-only --diff-filter=ACMR -- 'docs/*.md')
mapfile -t STAGED_ORDER < <(git diff --cached --name-only --diff-filter=ACMR -- 'scripts/reading_order.env')

if [[ ${#STAGED_DOCS[@]} -eq 0 && ${#STAGED_ORDER[@]} -eq 0 ]]; then
    exit 0
fi

echo "pre-commit: ${#STAGED_DOCS[@]} doc(s) and ${#STAGED_ORDER[@]} order-file change(s) staged."

# ---------------------------------------------------------------------------
# 1. TOC consistency — fix and re-stage.
# ---------------------------------------------------------------------------
if [[ ${#STAGED_DOCS[@]} -gt 0 ]]; then
    TOC_OUTPUT="$(python3 scripts/check_toc.py "${STAGED_DOCS[@]}" 2>&1 || true)"
    echo "$TOC_OUTPUT"

    mapfile -t STALE_TOC < <(echo "$TOC_OUTPUT" | awk '/^✗ STALE/ {print $3}')
    if [[ ${#STALE_TOC[@]} -gt 0 ]]; then
        echo
        echo "pre-commit: TOC stale in ${#STALE_TOC[@]} file(s) — regenerating..."
        STALE_PATHS=()
        for name in "${STALE_TOC[@]}"; do
            STALE_PATHS+=("docs/$name")
        done
        python3 scripts/update_toc.py "${STALE_PATHS[@]}"
        git add -- "${STALE_PATHS[@]}"
        echo "pre-commit: TOC updated and re-staged: ${STALE_PATHS[*]}"
    fi
fi

# ---------------------------------------------------------------------------
# 2. README regeneration — always run when docs or order file are staged.
# ---------------------------------------------------------------------------
echo
echo "pre-commit: regenerating docs/README.md from scripts/reading_order.env..."
README_EXIT=0
python3 scripts/update_readme.py || README_EXIT=$?
if [[ $README_EXIT -eq 2 ]]; then
    echo "pre-commit: update_readme.py reported a hard error. Commit aborted."
    exit 1
fi
# update_readme.py may have edited docs/README.md; re-stage it so the commit
# includes the regenerated section.
git add -- docs/README.md
if [[ $README_EXIT -eq 1 ]]; then
    echo
    echo "pre-commit: docs/README.md contains TODO placeholder description(s)."
    echo "  Edit docs/README.md to replace each TODO line with a curated"
    echo "  1–2 sentence description, then re-commit."
    exit 1
fi

# ---------------------------------------------------------------------------
# 3. Docs index consistency — README + Publication Summary + env coverage.
# ---------------------------------------------------------------------------
echo
echo "pre-commit: checking docs index..."
INDEX_TARGETS=("${STAGED_DOCS[@]}")
if ! python3 scripts/check_docs_index.py "${INDEX_TARGETS[@]}"; then
    echo
    echo "pre-commit: docs index check FAILED. Commit aborted."
    echo "  Fix: edit scripts/reading_order.env and the missing index, then re-commit."
    echo "  The /update-readme skill walks you through this."
    exit 1
fi

echo "pre-commit: all checks passed."
exit 0
